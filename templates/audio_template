{
  "globalInstructions": "Analyze the provided audio as an archivist and musicologist. Reference genre, instrumentation, mood, structure, and production details. If metadata is absent, infer ONLY from audible evidence.",
  "name": "Audio",
  "version": 2,
  "rules": [
    {
      "name": "Description",
      "type": "description",
      "replaceExisting": true,
      "includeNameAsTitle": false,
      "dependsOnRuleIds": [],
      "instruction": "Summarize what is heard (arrangement, vocals, mood). JSON output must be {\"description\": \"...\"}."
    },
    {
      "name": "Genre",
      "type": "tags",
      "tagsType": "example",
      "tagsList": [
        "Ambient", "Classical", "Electronic", "Hip-Hop", "Jazz",
        "Lo-fi", "Metal", "Pop", "Rock", "Soundtrack",
        "World", "Field Recording", "Podcast"
      ],
      "instruction": "Identify primary genres (max 3). Key must be 'genre'."
    },
    {
      "name": "Mood",
      "type": "tags",
      "tagsType": "example",
      "tagsList": [
        "Calm", "Energetic", "Melancholic", "Uplifting", "Dark",
        "Playful", "Intense", "Meditative"
      ],
      "instruction": "Describe emotional character (2–4 tags). Key 'mood'."
    },
    {
      "name": "Instrumentation",
      "type": "tags",
      "tagsType": "none",
      "instruction": "List audible instruments/voices incl. synth types or FX chains. Key 'instrumentation'."
    },
    {
      "name": "Structure",
      "type": "tags",
      "tagsType": "example",
      "tagsList": [
        "Intro", "Verse", "Chorus", "Bridge", "Drop",
        "Outro", "Loop", "Improvisation"
      ],
      "instruction": "Note notable sections or forms (ordered if possible). Key 'structure'."
    },
    {
      "name": "Production Traits",
      "type": "tags",
      "tagsType": "example",
      "tagsList": [
        "Lo-fi", "Hi-fi", "Analog", "Digital", "Live",
        "Studio", "Field Recording", "Stereo Wide", "Mono",
        "Heavy Compression", "Reverb-heavy"
      ],
      "instruction": "Summarize mix/recording characteristics. Key 'production'."
    },
    {
      "name": "Similar Artists",
      "type": "tags",
      "tagsType": "example",
      "instruction": "Provide 2–4 artists/producers/podcasts with comparable style. Key 'similar artists'."
    }
  ],
  "skipRule": {
    "tag": "Processed with AI Autotagger: Audio",
    "shouldAddOnSkip": false
  }
}
