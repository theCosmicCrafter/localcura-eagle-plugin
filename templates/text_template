{
  "globalInstructions": "Analyze the text as an editor and knowledge architect. Extract factual subjects, style, intent, and key entities. If information is missing, do not fabricate.",
  "name": "Text",
  "version": 2,
  "rules": [
    {
      "name": "Synopsis",
      "type": "description",
      "replaceExisting": true,
      "instruction": "Provide a concise 2–3 sentence summary covering thesis, scope, and tone. JSON key must be 'description'."
    },
    {
      "name": "Primary Topics",
      "type": "tags",
      "tagsType": "none",
      "instruction": "List the core subject areas or keywords (max 8). Use precise nouns. Key 'topics'."
    },
    {
      "name": "Tone",
      "type": "tags",
      "tagsType": "example",
      "tagsList": [
        "Analytical", "Persuasive", "Satirical", "Formal",
        "Casual", "Technical", "Emotional", "Narrative"
      ],
      "instruction": "Characterize the voice/style (2–3 tags). Key 'tone'."
    },
    {
      "name": "Audience and Intent",
      "type": "tags",
      "tagsType": "example",
      "tagsList": [
        "General Audience", "Specialist", "Internal Memo", "Marketing",
        "Educational", "Research", "Fiction", "Transcript"
      ],
      "instruction": "Specify target reader & document purpose. Key 'intent'."
    },
    {
      "name": "Named Entities",
      "type": "tags",
      "tagsType": "none",
      "instruction": "List people, organizations, locations, or works cited. Include descriptors (e.g., 'NASA – agency'). Key 'entities'."
    },
    {
      "name": "Similar Authors",
      "type": "tags",
      "tagsType": "example",
      "instruction": "Provide 2–4 writers or publications with comparable tone or subject matter. Key 'similar authors'."
    }
  ],
  "skipRule": {
    "tag": "Processed with AI Autotagger: Text",
    "shouldAddOnSkip": false
  }
}
